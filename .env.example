# docker-compose.prod.yml이 참조하는 값. VM에서 이 파일을 .env로 복사해 채운다.
# .env는 git-ignored이므로 절대 커밋하지 않는다.

# openssl rand -base64 48 등으로 생성한, appsettings.Development.json의
# 커밋된 개발용 키와는 다른 운영 전용 키.
JWT_KEY=

# /swagger, /openapi 접근용 Basic Auth. 비워두면 앱이 항상 401을 반환한다(열림 방지).
SWAGGER_USERNAME=
SWAGGER_PASSWORD=
